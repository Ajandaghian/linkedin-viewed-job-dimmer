{
  "manifest_version": 3,
  "name": "LinkedIn Viewed Job Dimmer",
  "version": "1.2.0",
  "description": "Dims viewed jobs in LinkedIn job search results and supports always-on mode.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["https://www.linkedin.com/jobs/*"],
  "action": {
    "default_title": "Dim viewed jobs",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
