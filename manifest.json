{
  "manifest_version": 3,
  "name": "LinkedIn Viewed Job Dimmer",
  "version": "1.2.1",
  "description": "Dims viewed jobs in LinkedIn job search results and supports always-on mode.",
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": [
    "https://linkedin.com/jobs/*",
    "https://*.linkedin.com/jobs/*"
  ],
  "action": {
    "default_title": "Dim viewed jobs",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://linkedin.com/jobs/*",
        "https://*.linkedin.com/jobs/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
