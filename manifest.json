{
  "manifest_version": 3,
  "name": "LinkedIn Viewed Job Dimmer",
  "version": "1.3.0",
  "description": "Dim viewed LinkedIn job cards in place, with an always-on mode and a dark gray disabled look.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": [
    "https://linkedin.com/jobs/*",
    "https://*.linkedin.com/jobs/*"
  ],
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "action": {
    "default_title": "Open LinkedIn Viewed Job Dimmer",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://linkedin.com/jobs/*",
        "https://*.linkedin.com/jobs/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
